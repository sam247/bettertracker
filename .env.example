# Database (Vercel Postgres / Neon)
DATABASE_URL=

# Auth — use a random string at least 32 characters
AUTH_SECRET=
AUTH_PASSWORD=

# Cron — Vercel sets this automatically when using cron; also add manually for local testing
CRON_SECRET=

# Serprobot API key from https://serprobot.com settings
SERPROBOT_API_KEY=

# Max keywords checked per cron run (default: 20)
CRON_BATCH_SIZE=20
