# Database — Vercel Postgres sets POSTGRES_URL automatically when you add the integration.
# For local drizzle-kit push, run: vercel env pull .env.local
DATABASE_URL=
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# Auth — use a random string at least 32 characters
AUTH_SECRET=
AUTH_PASSWORD=

# Cron — Vercel sets this automatically when using cron; also add manually for local testing
CRON_SECRET=

# Serprobot API key from https://serprobot.com settings
SERPROBOT_API_KEY=

# Max keywords checked per cron run (default: 20)
CRON_BATCH_SIZE=20
